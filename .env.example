# Copy to .env and fill in. Consumed by docker-compose.yml.  (.env is gitignored)

# Published images (built by .github/workflows/build.yml).
WEB_IMAGE=ghcr.io/deniel9204/mentesit-website-web:latest
CONTACT_IMAGE=ghcr.io/deniel9204/mentesit-website-contact:latest

# Host port the web container listens on (put your TLS proxy in front of it).
WEB_PORT=8080

# SMTP relay used by the contact form
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@mentesit.eu
MAIL_TO=info@mentesit.eu
SUCCESS_URL=https://mentesit.eu/kapcsolat/
