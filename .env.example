# Copy to .env and fill in. Consumed by docker-compose.yml.  (.env is gitignored)

# Published images (built by .github/workflows/build.yml).
WEB_IMAGE=ghcr.io/deniel9204/mentesit-website-web:latest
CONTACT_IMAGE=ghcr.io/deniel9204/mentesit-website-contact:latest

# Host port the web container listens on (put your TLS proxy in front of it).
WEB_PORT=8080

# SMTP relay used by the contact form
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@mentesit.eu
MAIL_TO=info@mentesit.eu
SUCCESS_URL=https://mentesit.eu/kapcsolat/

# CIDRs/IPs whose X-Forwarded-For header is trusted (your reverse proxy).
# Compose default is the internal web->contact network; override for a custom
# proxy. The Go service alone defaults to 127.0.0.0/8,::1/128 (host nginx).
TRUSTED_PROXIES=172.28.0.0/16

# Secret key that signs ALTCHA captcha challenges. Generate one with:
#   openssl rand -hex 32
# If empty, the service makes an ephemeral key at startup (fine for a single
# instance; set it for restarts-without-friction and multi-replica deploys).
ALTCHA_HMAC_KEY=
