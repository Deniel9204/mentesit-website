# Sample nginx vhost for MentesIT / FreeIT (static site).
# Copy to /etc/nginx/sites-available/mentesit.eu and adjust paths/certs.

# http -> https, and www -> apex
server {
    listen 80;
    listen [::]:80;
    server_name mentesit.eu www.mentesit.eu;
    return 301 https://mentesit.eu$request_uri;
}

# www -> apex over https
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name www.mentesit.eu;

    # ssl_certificate     /etc/letsencrypt/live/mentesit.eu/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/mentesit.eu/privkey.pem;

    return 301 https://mentesit.eu$request_uri;
}

# main site
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name mentesit.eu;

    root /var/www/mentesit/public;
    index index.html;

    # ssl_certificate     /etc/letsencrypt/live/mentesit.eu/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/mentesit.eu/privkey.pem;

    # Security headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    # add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    # Content-Security-Policy. 'unsafe-inline' for script-src covers ONLY the inline
    # JSON-LD blocks (structured data, not executable JS — there is no inline
    # JavaScript on the site). For a stricter policy use per-block sha256 hashes.
    # add_header Content-Security-Policy "default-src 'self'; img-src 'self' data:; script-src 'self' 'unsafe-inline'; style-src 'self'; font-src 'self'; form-action 'self'; base-uri 'self'; frame-ancestors 'self'" always;

    # Pretty URLs (Hugo emits .../index.html)
    location / {
        try_files $uri $uri/ $uri.html =404;
    }

    # Fingerprinted, content-hashed assets — cache hard.
    location ~* \.(css|js|woff2?|svg|png|jpe?g|webp|avif|ico)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # HTML & sitemap — always revalidate.
    location ~* \.(html|xml)$ {
        add_header Cache-Control "no-cache";
    }

    # Contact form endpoint — self-hosted Go service (see contact-service/).
    location = /api/contact {
        limit_except POST { deny all; }
        proxy_pass http://127.0.0.1:8081;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    error_page 404 /404.html;

    gzip_static on;
    # brotli_static on;   # if the brotli module is available
}
